# Copy your VENICE_API_KEY from gameV4/.env
VENICE_API_KEY=your_venice_api_key_here

# LLM Model Configuration (Optional - defaults provided)
# Models for different types of AI interactions
DEFAULT_STORY_MODEL=venice-uncensored
DEFAULT_SUMMARY_MODEL=mistral-31-24b  
DEFAULT_STORY_CONTEXT_MODEL=mistral-31-24b

# Temperature settings (0.0-2.0, lower = more focused, higher = more creative)
DEFAULT_STORY_TEMPERATURE=0.7
DEFAULT_SUMMARY_TEMPERATURE=0.3
DEFAULT_STORY_CONTEXT_TEMPERATURE=0.7

# Server Configuration (Optional - defaults provided)
# Server host and port for development and production
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=true

# CORS Configuration (Optional - defaults provided)
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000